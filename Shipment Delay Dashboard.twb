    <dashboard enable-sort-zone-taborder='true' name='Model Performance'>
      <style />
      <size maxheight='768' maxwidth='1366' minheight='768' minwidth='1366' preset-index='0' sizing-mode='fixed' />
      <zones>
        <zone h='69531' id='3' name='Model Comparison' w='57028' x='73' y='12891' />
        <zone h='19661' id='4' name='Model Comparison' pane-specification-id='0' param='[federated.10i9w380kuc3zn18pwid61kjjx4h].[:Measure Names]' type-v2='color' w='13690' x='57321' y='24219' />
        <zone h='26953' id='5' name='Metrics Table' w='42313' x='57174' y='47786' />
        <zone forceUpdate='true' h='8724' id='6' type-v2='text' w='91288' x='146' y='391'>
          <formatted-text>
            <run bold='true' fontcolor='#005493' fontsize='18'>Model Performance - Baseline vs Improved</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='11979' id='7' type-v2='text' w='90337' x='586' y='85156'>
          <formatted-text>
            <run fontcolor='#000000' fontname='Tableau Regular' fontsize='12'>The baseline Logistic Regression model achieved 58% accuracy but suffered from severe class imbalance it predicted almost every shipment as Delayed. </run>
            <run>Æ&#10;&#10;</run>
            <run fontcolor='#000000' fontname='Tableau Regular' fontsize='12'>The improved model applied SMOTE to balance training classes and used XGBoost with RandomizedSearchCV hyperparameter tuning. This increased accuracy to 74% and improved F1 score from 0.42 to 0.74 across all shipment classes.</run>
          </formatted-text>
        </zone>
      </zones>
