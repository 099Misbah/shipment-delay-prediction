    <dashboard enable-sort-zone-taborder='true' name='Prediction Insight'>
      <style />
      <size maxheight='768' maxwidth='1366' minheight='768' minwidth='1366' preset-index='0' sizing-mode='fixed' />
      <zones>
        <zone h='51432' id='3' name='Feature Importance' w='54539' x='659' y='15885' />
        <zone h='48958' id='4' name='Prediction Distribution' w='44583' x='55490' y='15885' />
        <zone h='10156' id='5' name='Prediction Distribution' pane-specification-id='0' param='[federated.1id3lxn1uqc63l184wy090c4bl7j].[none:Status:nk]' type-v2='color' w='10249' x='87994' y='14063' />
        <zone forceUpdate='true' h='7943' id='7' type-v2='text' w='75988' x='512' y='4036'>
          <formatted-text>
            <run bold='true' fontcolor='#005493' fontsize='18'>Feature Importance &amp; Prediction Distribution </run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='19661' id='8' type-v2='text' w='98170' x='1391' y='69141'>
          <formatted-text>
            <run fontcolor='#000000' fontsize='12'>Shipping mode and order priority are the strongest predictors of delay. This suggests that how a shipment is routed and how urgently it was flagged at order time have more impact on delivery outcome than the product type or customer location. </run>
            <run>Æ&#10;&#10;</run>
            <run fontcolor='#000000' fontsize='12'>Business implication: Logistics teams should prioritize reviewing Standard Class shipments and low-priority orders when proactively managing delay risk.</run>
          </formatted-text>
        </zone>
      </zones>
      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
